{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "vue", "vitest"],
  "env": {
    "browser": true
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {
    // Mock types are already checked by vue-tsc from assignment/usage
    // context; annotating every vi.fn() adds noise without safety.
    "vitest/require-mock-type-parameters": "off"
  }
}
